{
  "Jwt": {
    "Key": "SET_VIA_USER_SECRETS_OR_ENV_VAR__Jwt__Key",
    "Issuer": "SA.Identity",
    "Audience": "SA.Unazul"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-auth": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "identity-users": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/api/v1/users/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "identity-roles": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/api/v1/roles/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "identity-permissions": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/api/v1/permissions/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "organization-tenants": {
        "ClusterId": "organization",
        "Match": {
          "Path": "/api/v1/tenants/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "organization-entities": {
        "ClusterId": "organization",
        "Match": {
          "Path": "/api/v1/entities/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "catalog-families": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/v1/product-families/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "catalog-products": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/v1/products/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "catalog-commissions": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/v1/commission-plans/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "operations-applications": {
        "ClusterId": "operations",
        "Match": {
          "Path": "/api/v1/applications/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "operations-applicants": {
        "ClusterId": "operations",
        "Match": {
          "Path": "/api/v1/applicants/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "operations-settlements": {
        "ClusterId": "operations",
        "Match": {
          "Path": "/api/v1/settlements/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "config-parameters": {
        "ClusterId": "config",
        "Match": {
          "Path": "/api/v1/parameter-groups/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "config-params": {
        "ClusterId": "config",
        "Match": {
          "Path": "/api/v1/parameters/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "config-services": {
        "ClusterId": "config",
        "Match": {
          "Path": "/api/v1/external-services/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "config-workflows": {
        "ClusterId": "config",
        "Match": {
          "Path": "/api/v1/workflows/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "config-templates": {
        "ClusterId": "config",
        "Match": {
          "Path": "/api/v1/notification-templates/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      },
      "audit-log": {
        "ClusterId": "audit",
        "Match": {
          "Path": "/api/v1/audit-log/{**catch-all}"
        },
        "AuthorizationPolicy": "default"
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "organization": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "catalog": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "operations": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "config": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5005"
          }
        }
      },
      "audit": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5006"
          }
        }
      },
      "notification": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5007"
          }
        }
      }
    }
  }
}
