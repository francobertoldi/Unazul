{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:8080" ]
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 10
  }
}
